# =============================================================================
# 短剧多智能体系统 — 环境变量配置模板
# 用法：复制本文件为 .env，填入你的真实密钥；.env 不要提交到 git
# =============================================================================

# ---------- 大模型（任选其一，OpenAI 兼容接口即可） ----------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=httpsapi.deepseek.comv1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# 备选：字节豆包 Doubao
# LLM_API_KEY=your-doubao-api-key
# LLM_BASE_URL=httpsark.cn-beijing.volces.comapiv3
# LLM_MODEL=doubao-pro-32k

# 备选：OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=httpsapi.openai.comv1
# LLM_MODEL=gpt-4o-mini

# ---------- Embedding（可选，当前走本地 jieba 切分） ----------
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=bge-large-zh
EMBEDDING_DIM=1024

# ---------- 向量检索 ----------
VECTOR_INDEX_PATH=datafaiss_index
MATERIAL_KNOWLEDGE_PATH=dataknowledge
RETRIEVE_TOP_K=20
RERANK_TOP_K=3
ENABLE_RERANK=true

# ---------- 合规审核 ----------
AUDIT_MAX_ITERATION=3
AUDIT_PASS_THRESHOLD=0.8

# ---------- 服务 ----------
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
